{# core/registration.html.twig #}
{% extends "core/common/template.html.twig" %}
{% trans_default_domain 'core' %}

{% block title %}
    {{ 'site.title.core.registration'|trans({}, 'site') }}
{% endblock %}

{% block body %}
    {% set transKey = 'core.form.registration.' %}
    <div class="flex items-center justify-center min-h-screen bg-gray-50">
        <div class="w-full max-w-sm bg-white rounded-xl border border-gray-200 p-8">

            <h4 class="text-lg font-semibold text-gray-900 mb-1">{{ (transKey ~ 'title')|trans }}</h4>

            <turbo-frame id="registration-form">
                {% include 'core/registration_form.html.twig' %}
            </turbo-frame>

            <p class="mt-4 text-center text-sm text-gray-500">
                {{ (transKey ~ 'got.account')|trans }}
                <a href="{{ path('core_login') }}" class="text-blue-600 hover:underline">{{ (transKey ~ 'login')|trans }}</a>
            </p>

        </div>
    </div>
{% endblock %}
