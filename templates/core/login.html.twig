{% extends "core/common/template.html.twig" %}
{% trans_default_domain 'core' %}

{% block title %}
    {{ 'site.title.core.login'|trans({}, 'site') }}
{% endblock %}

{% block body %}
    {% set transKey = 'core.form.login.' %}
    <div class="flex items-center justify-center min-h-screen">
        <div class="w-full max-w-sm bg-white rounded-xl border border-gray-200 p-8">

            <h4 class="text-lg font-semibold text-gray-900 mb-1">{{ (transKey ~ 'title')|trans }}</h4>

            {% if error %}
                <div class="mb-4 p-3 rounded-lg bg-red-50 text-red-700 text-sm">
                    {{ error.messageKey|trans(error.messageData, 'security') }}
                </div>
            {% endif %}

            {{ form(form) }}

            <p class="mt-4 text-center text-sm text-gray-500">
                {{ (transKey ~ 'no.account')|trans }}
                <a href="{{ path('core_registration') }}" class="text-blue-600 hover:underline">{{ (transKey ~ 'register')|trans }}</a>
            </p>

        </div>
    </div>
{% endblock %}
