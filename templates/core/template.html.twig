{# core/template.html.twig #}
<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>{% block title %}Test{% endblock %}</title>
    <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>⚫️</text><text y=%221.3em%22 x=%220.2em%22 font-size=%2276%22 fill=%22%23fff%22>sf</text></svg>">
    {% block stylesheets %}{% endblock %}
    {% block javascripts %}
        {% block importmap %}{{ importmap('app') }}{% endblock %}
    {% endblock %}
</head>
<body class="flex flex-col min-h-screen bg-gray-50 text-gray-900">

{% block header %}
    <nav class="bg-gray-900 text-white">
        <div class="px-4 py-3 flex flex-col items-center">
            <h1 class="text-xl font-semibold tracking-wide mb-2">{{ 'site.title' }}</h1>

            {% if app.user !== null %}
                <div class="flex w-full items-center">
                    <ul class="flex items-center gap-1">
                        <li>
                            <a href="{{ url('core_home_view') }}"
                               class="px-3 py-1.5 rounded text-sm text-gray-300 hover:text-white hover:bg-gray-700 transition-colors">
                                {{ 'menu.home'|trans }}
                            </a>
                        </li>

                        {# Dropdown – czysty CSS, bez JS #}
                        <li class="relative group">
                            <button class="flex items-center gap-1 px-3 py-1.5 rounded text-sm text-gray-300 hover:text-white hover:bg-gray-700 transition-colors cursor-pointer">
                                {{ 'menu.messenger'|trans }}
                                <svg class="w-3.5 h-3.5 mt-px" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
                                </svg>
                            </button>
                            <ul class="absolute left-0 top-full mt-1 w-40 bg-gray-800 border border-gray-700 rounded shadow-lg
                                               opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-150 z-50">
                                <li>
                                    <a href="{{ url('chat_mercure_chats_list') }}"
                                       class="block px-4 py-2 text-sm text-gray-300 hover:text-white hover:bg-gray-700 transition-colors">
                                        {{ 'menu.messenger.chat'|trans }}
                                    </a>
                                </li>
                            </ul>
                        </li>
                    </ul>

                    <ul class="flex items-center ml-auto">
                        <li>
                            <a href="{{ url('core_logout') }}"
                               class="px-3 py-1.5 rounded text-sm text-gray-300 hover:text-white hover:bg-gray-700 transition-colors">
                                {{ 'menu.logout'|trans }}
                            </a>
                        </li>
                    </ul>
                </div>
            {% endif %}
        </div>
    </nav>
{% endblock %}

<main class="flex-1">
    {% block body %}{% endblock %}
</main>

{% block footer %}
    <footer class="mt-auto py-4 bg-gray-900 text-gray-400 text-center text-sm">
        <p>Footer</p>
    </footer>
{% endblock %}

</body>
</html>
