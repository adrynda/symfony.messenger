{# templates/form/tailwind_theme.html.twig #}
{% use 'tailwind_2_layout.html.twig' %}

{% block form_row %}
    {% set row_class = row_class|default('mb-4') %}
    {{ parent() }}
{% endblock %}

{% block form_label %}
    {% set label_class = label_class|default('block text-sm font-medium text-gray-700 mb-1') %}
    {{ parent() }}
{% endblock %}

{% block form_widget_simple %}
    {% set widget_class = widget_class|default('w-full rounded-lg border border-gray-300 px-4 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500') %}
    {{ parent() }}
{% endblock %}

{% block button_widget %}
    {% set attr = attr|merge({class: attr.class|default('w-full bg-blue-600 hover:bg-blue-700 text-white font-semibold py-2 px-4 rounded-lg transition duration-200')}) %}
    {{ parent() }}
{% endblock %}
