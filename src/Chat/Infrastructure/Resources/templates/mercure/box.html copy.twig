<script>
  const chatData = JSON.parse('{{ chat.toArray()|json_encode()|raw }}');
  document.addEventListener("DOMContentLoaded", () => {
    // console.log(chatData);
    Chat.fromJson(chatData);
    // console.log(window.mercure);
  });


  class Chat
  {
    #id;
    #users = [];
    #messages = [];

    static fromJson(data)
    {
      window.chat = new Chat(data.id);

      data.users.forEach((userData) => {
        window.chat.addUser(User.fromJson(userData));
      });

      data.messages.forEach((messageData) => {
        window.chat.addMessage(Message.fromJson(messageData));
      });

      return window.chat;
    }

    constructor (id)
    {
      this.#id = id;
    }

    addUser(user)
    {
      this.#users.push(user);
    }

    findUser(id)
    {
      return this.#users.filter((user) => {
        return user.getId() == id;
      })[0] || null;
    }

    addMessage(message)
    {
      this.#messages.push(message);
    }
  }

  class Message
  {
    #id;
    #user;
    #sentAt;
    #content;

    static fromJson(data)
    {
      return new Message(
        data.id,
        window.chat.findUser(data.user_id),
        data.sentAt,
        data.content,
      );
    }

    constructor(id, user, sentAt, content)
    {
      this.#id = id;
      this.#user = user;
      this.#sentAt = sentAt;
      this.#content = content;
    }

    getId()
    {
      return this.#id;
    }

    getUser()
    {
      return this.#user;
    }

    getSentAt()
    {
      return this.#sentAt;
    }

    getContent()
    {
      return this.#content;
    }
  }

  class User
  {
    #id;
    #username;
    #avatar;

    static fromJson(data)
    {
      return new User(data.id, data.username, data.avatar);
    }

    constructor (id, username, avatar)
    {
      this.#id = id;
      this.#username = username;
      this.#avatar = avatar;
    }

    getId()
    {
      return this.#id;
    }

    getUsername()
    {
      return this.#username;
    }

    getAvatar()
    {
      return this.#avatar;
    }
  }
</script>
